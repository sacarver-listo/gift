<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>a question for you</title>
<style>
  /* ============================================================
     EDIT THESE to personalize the page — everything else works
     automatically once these are filled in.
  ============================================================ */
  :root {
    --recipient-name: "you";           /* shows in the headline */
  }

  @import url('https://fonts.googleapis.com/css2?family=Baloo+2:wght@500;700;800&family=Nunito:wght@400;600;700&display=swap');

  * { box-sizing: border-box; }

  html, body {
    margin: 0;
    padding: 0;
    min-height: 100vh;
    width: 100%;
    overflow-x: hidden;
    font-family: 'Nunito', sans-serif;
    background: linear-gradient(160deg, #FFE1EC 0%, #FFD3E0 35%, #FFEAC2 100%);
    position: relative;
  }

  /* floating candy hearts drifting in the background */
  .drift {
    position: fixed;
    top: -60px;
    font-size: 28px;
    opacity: 0.55;
    animation: fall linear infinite;
    pointer-events: none;
    user-select: none;
    z-index: 0;
  }
  @keyframes fall {
    0%   { transform: translateY(0) rotate(0deg); }
    100% { transform: translateY(110vh) rotate(360deg); }
  }

  .stage {
    position: relative;
    z-index: 1;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px;
  }

  .card {
    background: #FFFDF9;
    border-radius: 32px;
    padding: 48px 36px 40px;
    max-width: 460px;
    width: 100%;
    text-align: center;
    box-shadow: 0 20px 50px rgba(216, 70, 110, 0.18), 0 2px 0 #FFFFFF inset;
    position: relative;
    transform: rotate(-1deg);
    transition: transform 0.4s ease;
  }
  .card:hover { transform: rotate(0deg); }

  .candy {
    width: 92px;
    height: 92px;
    margin: 0 auto 18px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 46px;
    background: radial-gradient(circle at 35% 30%, #FF9EB5, #FF6F91 70%);
    border-radius: 50%;
    box-shadow: 0 10px 22px rgba(255, 111, 145, 0.45);
    animation: bob 2.6s ease-in-out infinite;
  }
  @keyframes bob {
    0%, 100% { transform: translateY(0) rotate(-4deg); }
    50%      { transform: translateY(-8px) rotate(4deg); }
  }

  .eyebrow {
    font-family: 'Nunito', sans-serif;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-size: 12px;
    color: #E85D8A;
    margin-bottom: 8px;
  }

  h1 {
    font-family: 'Baloo 2', sans-serif;
    font-weight: 800;
    font-size: clamp(28px, 6vw, 38px);
    line-height: 1.15;
    color: #4A2E3A;
    margin: 0 0 12px;
  }
  h1 span {
    color: #FF6F91;
  }

  .sub {
    font-size: 15.5px;
    color: #8A6E78;
    margin: 0 0 30px;
    line-height: 1.5;
  }

  .buttons {
    position: relative;
    display: flex;
    gap: 14px;
    justify-content: center;
    min-height: 64px;
  }

  button {
    font-family: 'Baloo 2', sans-serif;
    font-weight: 700;
    font-size: 18px;
    border: none;
    border-radius: 999px;
    padding: 14px 30px;
    cursor: pointer;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }

  #yesBtn {
    background: #FF6F91;
    color: #fff;
    box-shadow: 0 8px 20px rgba(255, 111, 145, 0.45);
  }
  #yesBtn:hover { transform: scale(1.06); }
  #yesBtn:active { transform: scale(0.97); }

  #noBtn {
    background: #FFF0E9;
    color: #C77A6F;
    box-shadow: 0 4px 10px rgba(0,0,0,0.05);
    position: relative;
    transition: left 0.18s ease, top 0.18s ease, transform 0.15s ease;
  }

  .noBtn-fixed {
    position: fixed !important;
  }

  .grow {
    font-size: calc(18px + var(--grow, 0) * 2px);
    padding: calc(14px + var(--grow, 0) * 1.5px) calc(30px + var(--grow, 0) * 3px);
  }

  /* ---- reveal state ---- */
  .reveal {
    display: none;
  }
  .reveal.show {
    display: block;
    animation: pop 0.5s cubic-bezier(.26,1.6,.5,1);
  }
  @keyframes pop {
    0%   { transform: scale(0.6); opacity: 0; }
    100% { transform: scale(1); opacity: 1; }
  }
  .reveal h2 {
    font-family: 'Baloo 2', sans-serif;
    font-size: 26px;
    color: #4A2E3A;
    margin: 6px 0 10px;
  }
  .reveal p {
    color: #8A6E78;
    font-size: 15px;
    line-height: 1.6;
    margin: 0;
  }
  .reveal .big-heart {
    font-size: 44px;
    animation: beat 1s ease-in-out infinite;
  }
  @keyframes beat {
    0%, 100% { transform: scale(1); }
    50%      { transform: scale(1.18); }
  }

  .ask.hidden { display: none; }

  .confetti-piece {
    position: fixed;
    top: -20px;
    width: 10px;
    height: 14px;
    z-index: 5;
    pointer-events: none;
    animation: confetti-fall linear forwards;
  }
  @keyframes confetti-fall {
    to { transform: translateY(110vh) rotate(540deg); opacity: 0.9; }
  }

  @media (prefers-reduced-motion: reduce) {
    .drift, .candy, .reveal .big-heart, .confetti-piece { animation: none !important; }
  }
</style>
</head>
<body>

<div class="stage">
  <div class="card">

    <div class="ask" id="askBlock">
      <div class="candy">🍬</div>
      <div class="eyebrow">a small, important question</div>
      <h1>Hey <span id="nameSlot">you</span> — <br>go on a date with me?</h1>
      <p class="sub">No pressure. Just a candy-shaped question sitting here, waiting for an answer.</p>

      <div class="buttons" id="btnRow">
        <button id="yesBtn">Yes 🍭</button>
        <button id="noBtn">No</button>
      </div>
    </div>

    <div class="reveal" id="revealBlock">
      <div class="big-heart">💗</div>
      <h2>Yesss! It's a date.</h2>
      <p>I'll find us somewhere good — coffee, a walk, or whatever sounds fun to you. Can't wait.</p>
    </div>

  </div>
</div>

<script>
  // background drifting candy hearts
  const emojis = ["🍬","💗","🍭","✨"];
  for (let i = 0; i < 16; i++) {
    const el = document.createElement("div");
    el.className = "drift";
    el.textContent = emojis[Math.floor(Math.random() * emojis.length)];
    el.style.left = Math.random() * 100 + "vw";
    el.style.animationDuration = (10 + Math.random() * 10) + "s";
    el.style.animationDelay = (Math.random() * -20) + "s";
    el.style.fontSize = (18 + Math.random() * 20) + "px";
    document.body.appendChild(el);
  }

  document.getElementById("nameSlot").textContent =
    getComputedStyle(document.documentElement).getPropertyValue('--recipient-name').replace(/"/g, '').trim() || "you";

  const noBtn = document.getElementById("noBtn");
  const yesBtn = document.getElementById("yesBtn");
  const btnRow = document.getElementById("btnRow");
  let dodges = 0;

  function dodge() {
    dodges++;
    const rect = btnRow.getBoundingClientRect();
    const margin = 60;
    const maxX = window.innerWidth - margin;
    const maxY = window.innerHeight - margin;
    const newX = Math.max(margin, Math.random() * maxX);
    const newY = Math.max(margin, Math.random() * maxY);

    noBtn.classList.add("noBtn-fixed");
    noBtn.style.left = newX + "px";
    noBtn.style.top = newY + "px";

    // grows a little each time, and yes button grows to match its enthusiasm
    yesBtn.style.setProperty("--grow", Math.min(dodges, 6));
    yesBtn.classList.add("grow");

    const teases = ["nope!", "try again", "so close", "nice try", "almost", "keep trying", "not today", "gotcha"];
    if (dodges <= teases.length) noBtn.textContent = teases[dodges - 1];
  }

  noBtn.addEventListener("mouseenter", dodge);
  noBtn.addEventListener("click", (e) => { e.preventDefault(); dodge(); });
  noBtn.addEventListener("touchstart", (e) => { e.preventDefault(); dodge(); }, { passive: false });

  function launchConfetti() {
    const colors = ["#FF6F91", "#FFD166", "#8FD9C4", "#FF9EB5", "#FFB6C1"];
    for (let i = 0; i < 80; i++) {
      const piece = document.createElement("div");
      piece.className = "confetti-piece";
      piece.style.left = Math.random() * 100 + "vw";
      piece.style.background = colors[Math.floor(Math.random() * colors.length)];
      piece.style.animationDuration = (2 + Math.random() * 1.5) + "s";
      piece.style.animationDelay = (Math.random() * 0.4) + "s";
      piece.style.borderRadius = Math.random() > 0.5 ? "50%" : "2px";
      document.body.appendChild(piece);
      setTimeout(() => piece.remove(), 4000);
    }
  }

  yesBtn.addEventListener("click", () => {
    document.getElementById("askBlock").classList.add("hidden");
    document.getElementById("revealBlock").classList.add("show");
    launchConfetti();
  });
</script>

</body>
</html>
